# Environment Variables for VeriShare Backend

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/verishare

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d


# To generate a strong JWT secret, node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# Other configurations can be added as needed
# BLOCKDAG_API_URL=
# IPFS_GATEWAY_URL=